generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  createdAt DateTime @default(now())
  families  FamilyMember[]
  ownedFamilies Family[] @relation("FamilyOwner")
}

model Family {
  id        String   @id @default(uuid())
  name      String
  ownerId   String
  owner     User     @relation("FamilyOwner", fields: [ownerId], references: [id])
  members   Member[]
  plans     WeeklyPlan[]
  createdAt DateTime @default(now())
}

model FamilyMember {
  userId   String
  familyId String
  user     User   @relation(fields: [userId], references: [id])
  @@id([userId, familyId])
}

model Member {
  id           String       @id @default(uuid())
  familyId     String
  family       Family       @relation(fields: [familyId], references: [id])
  name         String
  avatarUrl    String?
  preferences  MemberPreference[]
  restrictions DietaryRestriction[]
  planDays     PlanDayMember[]
  feedbacks    RecipeFeedback[]
}

model MemberPreference {
  id       String @id @default(uuid())
  memberId String
  member   Member @relation(fields: [memberId], references: [id])
  foodTag  String
  score    Int    @default(1) // +1 le gusta, -1 no le gusta
}

model DietaryRestriction {
  id       String @id @default(uuid())
  memberId String
  member   Member @relation(fields: [memberId], references: [id])
  type     String // "vegetarian" | "gluten_free" | "lactose_free" | etc
}

model Recipe {
  id            String   @id @default(uuid())
  name          String
  prepMinutes   Int
  difficulty    String   @default("easy")
  recipeUrl     String?
  tags          String[] // ["vegetarian", "pasta", "pollo", etc]
  costEstimate  Float?
  ingredients   RecipeIngredient[]
  planDays      PlanDay[]
  feedbacks     RecipeFeedback[]
  createdAt     DateTime @default(now())
}

model Ingredient {
  id       String @id @default(uuid())
  name     String @unique
  category String // "carnes" | "verduras" | "secos" | "lácteos" | etc
  unit     String @default("gr")
  recipes  RecipeIngredient[]
  shoppingItems ShoppingListItem[]
}

model RecipeIngredient {
  recipeId     String
  ingredientId String
  quantity     Float
  unit         String
  recipe       Recipe     @relation(fields: [recipeId], references: [id])
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  @@id([recipeId, ingredientId])
}

model WeeklyPlan {
  id        String    @id @default(uuid())
  familyId  String
  family    Family    @relation(fields: [familyId], references: [id])
  weekStart DateTime
  status    String    @default("draft") // "draft" | "confirmed"
  days      PlanDay[]
  shoppingItems ShoppingListItem[]
  createdAt DateTime  @default(now())
}

model PlanDay {
  id        String   @id @default(uuid())
  planId    String
  plan      WeeklyPlan @relation(fields: [planId], references: [id])
  dayDate   DateTime
  mealType  String   @default("dinner") // "lunch" | "dinner"
  recipeId  String
  recipe    Recipe   @relation(fields: [recipeId], references: [id])
  members   PlanDayMember[]
}

model PlanDayMember {
  planDayId String
  memberId  String
  planDay   PlanDay @relation(fields: [planDayId], references: [id])
  member    Member  @relation(fields: [memberId], references: [id])
  @@id([planDayId, memberId])
}

model ShoppingListItem {
  id           String     @id @default(uuid())
  planId       String
  plan         WeeklyPlan @relation(fields: [planId], references: [id])
  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  quantity     Float
  unit         String
  haveAtHome   Boolean    @default(false)
}

model RecipeFeedback {
  id        String   @id @default(uuid())
  recipeId  String
  recipe    Recipe   @relation(fields: [recipeId], references: [id])
  memberId  String
  member    Member   @relation(fields: [memberId], references: [id])
  rating    Int      // 1-3
  createdAt DateTime @default(now())
  @@unique([recipeId, memberId, createdAt])
}